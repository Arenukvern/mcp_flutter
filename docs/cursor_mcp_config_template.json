{
  "mcpServers": {
    "flutter-mcp-toolkit": {
      "command": "/absolute/path/to/mcp_server_dart/build/flutter-mcp-toolkit-server",
      "args": [
        "--dart-vm-host=localhost",
        "--dart-vm-port=8181",
        "--resources",
        "--images"
      ],
      "env": {},
      "disabled": false
    },
    "flutter-mcp-toolkit-files": {
      "command": "/absolute/path/to/mcp_server_dart/build/flutter-mcp-toolkit-server",
      "args": [
        "--dart-vm-host=localhost",
        "--dart-vm-port=8181",
        "--resources",
        "--images",
        "--save-images"
      ],
      "env": {},
      "disabled": false
    }
  }
}
